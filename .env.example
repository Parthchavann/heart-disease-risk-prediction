# Heart Disease Risk Prediction API Configuration
# Copy this file to .env and update with your values

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# LLM Configuration (Optional - system works without LLM)
OPENAI_API_KEY=your_openai_key_here
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=500

# Logging Configuration
LOG_LEVEL=INFO
LOG_DIR=logs

# Security
SECRET_KEY=your-secret-key-here-change-in-production

# Risk Level Thresholds
LOW_RISK_THRESHOLD=0.3
HIGH_RISK_THRESHOLD=0.7

# Model Configuration
RANDOM_STATE=42
CV_FOLDS=5
TEST_SIZE=0.15
VAL_SIZE=0.15

# Data Paths
DATA_DIR=data
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
MODELS_DIR=data/models

# UCI Dataset URL
UCI_HEART_DISEASE_URL=https://archive.ics.uci.edu/ml/machine-learning-databases/heart-disease/processed.cleveland.data